generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  teamOwnerId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  settings        Settings?
  folders         Folder[]
  notes           Note[]
  tasks           Task[]
  tags            Tag[]
  voiceNotes      VoiceNote[]
  passwordEntries PasswordEntry[]
  issues          Issue[]
  agents          Agent[]
  artifacts       Artifact[]
  artifactFolders ArtifactFolder[]
  savedNews       SavedNews[]
  codeFolders     CodeFolder[]
  codeItems       CodeItem[]
  links           Link[]
  teamOwner       User?    @relation("TeamMembers", fields: [teamOwnerId], references: [id], onDelete: SetNull)
  teamMembers     User[]   @relation("TeamMembers")

  @@map("users")
}

model Settings {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  theme                   String   @default("dark") // "dark" | "light"
  accentColor             String   @default("purple")
  accentHue               Int?
  fontFamily              String?
  language                String   @default("pt") // "pt" | "en"
  logoUrl                 String?
  avatarUrl               String?
  vaultSalt               String?  @db.Text
  vaultWrappedKey         String?  @db.Text
  vaultRecoveryWrappedKey String?  @db.Text
  vaultKdfIterations      Int?
  vaultAutoLockSeconds    Int      @default(60)
  issueStatuses           Json?
  trashRetentionDays      Int      @default(30) // 0 = never auto-purge
  sidebarLayout           Json? // [{ key: "notes", hidden: false }, ...] — order + visibility of sidebar nav items (Trash/Settings excluded, always shown)
  hostingerApiTokenEnc    String?  @db.Text // AES-256-GCM encrypted at rest, server never exposes plaintext to the client
  hostingerVpsId          String?
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("settings")
}

model Folder {
  id        String   @id @default(uuid())
  userId    String
  parentId  String?
  name      String
  createdAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes    Note[]
  parent   Folder?  @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Folder[] @relation("FolderTree")

  @@index([parentId])
  @@map("folders")
}

model Note {
  id        String    @id @default(uuid())
  userId    String
  folderId  String?
  title     String
  content   String    @db.LongText
  blocks    Json?
  tags      Json?
  links     Json?
  pinned    Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  versions NoteVersion[]

  @@index([userId])
  @@index([folderId])
  @@map("notes")
}

model NoteVersion {
  id        String   @id @default(uuid())
  noteId    String
  title     String
  content   String   @db.LongText
  blocks    Json?
  createdAt DateTime @default(now())

  note Note @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt])
  @@map("note_versions")
}

model Task {
  id        String   @id @default(uuid())
  userId    String
  title     String
  done      Boolean  @default(false)
  status    String   @default("todo") // "todo" | "in_progress" | "done"
  priority  String   @default("Medium") // "Low" | "Medium" | "High"
  due       String?
  project   String?
  notes     String?  @db.Text
  favorite  Boolean  @default(false)
  recurrence String? // "daily" | "weekly" | "monthly"
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("tasks")
}

model Tag {
  id        String   @id @default(uuid())
  userId    String
  name      String
  hue       Int      @default(290)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("tags")
}

model VoiceNote {
  id        String   @id @default(uuid())
  userId    String
  title     String
  audioUrl  String
  duration  Int      @default(0)
  notes     String?  @db.Text
  favorite  Boolean  @default(false)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("voice_notes")
}

model PasswordEntry {
  id        String   @id @default(uuid())
  userId    String
  envelope  String   @db.Text // base64(iv + AES-GCM ciphertext) of the JSON entry, encrypted client-side with the vault master key
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_entries")
}

model Issue {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String?   @db.Text
  status      String    @default("Open") // Open | In Progress | Waiting | Done
  priority    String    @default("Medium") // Low | Medium | High | Critical
  waitingOn   String?
  completedAt DateTime?
  due         String?
  project     String?
  notes       String?   @db.Text
  favorite    Boolean   @default(false)
  recurrence  String? // "daily" | "weekly" | "monthly"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("issues")
}

model Agent {
  id          String   @id @default(uuid())
  userId      String
  name        String
  provider    String   @default("anthropic") // "anthropic" | "openai"
  baseUrl     String?
  model       String?
  tokenCipher String   @db.Text
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AgentMessage[]

  @@index([userId])
  @@map("agents")
}

model AgentMessage {
  id        String   @id @default(uuid())
  agentId   String
  role      String // "user" | "assistant"
  content   String   @db.Text
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@map("agent_messages")
}

model Artifact {
  id          String   @id @default(uuid())
  userId      String
  folderId    String?
  title       String
  description String?  @db.Text
  html        String   @db.LongText
  tags        Json?
  favorite    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder ArtifactFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([folderId])
  @@map("artifacts")
}

// Same nested-folder shape as Notes' Folder model, kept separate so an
// artifact folder tree doesn't mix with the Notes one.
model ArtifactFolder {
  id        String   @id @default(uuid())
  userId    String
  parentId  String?
  name      String
  createdAt DateTime @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  artifacts Artifact[]
  parent    ArtifactFolder?  @relation("ArtifactFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children  ArtifactFolder[] @relation("ArtifactFolderTree")

  @@index([userId])
  @@index([parentId])
  @@map("artifact_folders")
}

model SavedNews {
  id        String   @id @default(uuid())
  userId    String
  newsId    String
  title     String
  source    String?
  image     String?  @db.Text
  summary   String?  @db.Text
  content   String?  @db.LongText
  link      String   @db.Text
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, newsId])
  @@index([userId])
  @@map("saved_news")
}

model CodeFolder {
  id          String   @id @default(uuid())
  userId      String
  parentId    String?
  name        String // ABAP object name, e.g. ZMY_PROGRAM
  kind        String   @default("program") // "program" | "class" | "function_module"
  description String?  @db.Text
  tags        Json?
  linkedFolderIds Json?
  favorite    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  items    CodeItem[]
  parent   CodeFolder?  @relation("CodeFolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children CodeFolder[] @relation("CodeFolderTree")

  @@index([userId])
  @@index([parentId])
  @@map("code_folders")
}

model CodeItem {
  id         String   @id @default(uuid())
  folderId   String
  userId     String
  type       String // "snippet" | "characteristics" | "table" | "data_element" | "domain"
  name       String
  language   String   @default("abap")
  content    String?  @db.LongText
  attributes Json?
  position   Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  folder CodeFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([folderId])
  @@index([userId])
  @@map("code_items")
}

// Generic cross-entity link — lets a Note/Issue/Task/CodeItem point at any
// other entity of any of those types, not just Note-to-Note (the older
// Note.links Json field). Kept separate from that field rather than
// migrating it, so the existing Notes-to-Notes linking UI/data is untouched.
model Link {
  id        String   @id @default(uuid())
  userId    String
  fromType  String // "note" | "issue" | "task" | "code"
  fromId    String
  toType    String
  toId      String
  label     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, fromType, fromId])
  @@index([userId, toType, toId])
  @@map("links")
}
