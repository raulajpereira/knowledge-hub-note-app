generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  teamOwnerId  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  settings        Settings?
  folders         Folder[]
  notes           Note[]
  tasks           Task[]
  tags            Tag[]
  voiceNotes      VoiceNote[]
  passwordEntries PasswordEntry[]
  issues          Issue[]
  agents          Agent[]
  artifacts       Artifact[]
  teamOwner       User?    @relation("TeamMembers", fields: [teamOwnerId], references: [id], onDelete: SetNull)
  teamMembers     User[]   @relation("TeamMembers")

  @@map("users")
}

model Settings {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  theme                   String   @default("dark") // "dark" | "light"
  accentColor             String   @default("purple")
  accentHue               Int?
  fontFamily              String?
  language                String   @default("pt") // "pt" | "en"
  logoUrl                 String?
  avatarUrl               String?
  vaultSalt               String?  @db.Text
  vaultWrappedKey         String?  @db.Text
  vaultRecoveryWrappedKey String?  @db.Text
  vaultKdfIterations      Int?
  vaultAutoLockSeconds    Int      @default(60)
  issueStatuses           Json?
  updatedAt               DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("settings")
}

model Folder {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes Note[]

  @@map("folders")
}

model Note {
  id        String    @id @default(uuid())
  userId    String
  folderId  String?
  title     String
  content   String    @db.LongText
  blocks    Json?
  tags      Json?
  pinned    Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder Folder? @relation(fields: [folderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([folderId])
  @@map("notes")
}

model Task {
  id        String   @id @default(uuid())
  userId    String
  title     String
  done      Boolean  @default(false)
  priority  String   @default("Medium") // "Low" | "Medium" | "High"
  due       String?
  project   String?
  notes     String?  @db.Text
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("tasks")
}

model Tag {
  id        String   @id @default(uuid())
  userId    String
  name      String
  hue       Int      @default(290)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@map("tags")
}

model VoiceNote {
  id        String   @id @default(uuid())
  userId    String
  title     String
  audioUrl  String
  duration  Int      @default(0)
  notes     String?  @db.Text
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("voice_notes")
}

model PasswordEntry {
  id        String   @id @default(uuid())
  userId    String
  envelope  String   @db.Text // base64(iv + AES-GCM ciphertext) of the JSON entry, encrypted client-side with the vault master key
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_entries")
}

model Issue {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String?   @db.Text
  status      String    @default("Open") // Open | In Progress | Waiting | Done
  priority    String    @default("Medium") // Low | Medium | High | Critical
  waitingOn   String?
  completedAt DateTime?
  due         String?
  project     String?
  notes       String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("issues")
}

model Agent {
  id          String   @id @default(uuid())
  userId      String
  name        String
  provider    String   @default("anthropic") // "anthropic" | "openai"
  baseUrl     String?
  tokenCipher String   @db.Text
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages AgentMessage[]

  @@index([userId])
  @@map("agents")
}

model AgentMessage {
  id        String   @id @default(uuid())
  agentId   String
  role      String // "user" | "assistant"
  content   String   @db.Text
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@map("agent_messages")
}

model Artifact {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?  @db.Text
  html        String   @db.LongText
  tags        Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("artifacts")
}
